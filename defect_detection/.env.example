# Copy to .env and fill in values

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/defect_db

# Paths
CHECKPOINT_DIR=data/checkpoints
SYNTHETIC_DIR=data/synthetic
REAL_DIR=data/real

# GAN training
IMAGE_SIZE=64
LATENT_DIM=100
NUM_CLASSES=2
BATCH_SIZE=32
EPOCHS=200
LEARNING_RATE=0.0002

APP_ENV=development
